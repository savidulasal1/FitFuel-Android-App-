<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/backgroundcolor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ==================== USER INFO ==================== -->
        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome!"
            android:textSize="23sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textSize="14sp"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- ==================== DAILY GOAL ==================== -->
        <TextView
            android:id="@+id/tv_daily_goal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily Goal: Loading..."
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/buttonColor"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 0 cal"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/progress_bar_goal"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="#E0E0E0"
            android:progressTint="@color/buttonColor"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="24dp">

            <!-- CARD 1: Today's Meals -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_today_meals"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFF3E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_food"
                        android:tint="#FF6D00" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Meals"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#D84315"
                        android:layout_marginTop="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 2: 7-Day History -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_history"
                android:layout_width="0dp"
                android:layout_height="130dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#E8F5E9"
                android:outlineSpotShadowColor="@color/black">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_history"
                        android:tint="#2E7D32" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7-Day History"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginTop="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ==================== MEAL SECTIONS ==================== -->
        <include
            android:id="@+id/meal_breakfast"
            layout="@layout/meal_section" />

        <include
            android:id="@+id/meal_lunch"
            layout="@layout/meal_section" />

        <include
            android:id="@+id/meal_snack"
            layout="@layout/meal_section" />

        <include
            android:id="@+id/meal_dinner"
            layout="@layout/meal_section" />


        <!-- ==================== LOGOUT BUTTON ==================== -->
        <Button
            android:id="@+id/logout"
            android:layout_width="97dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/buttonColor"
            android:gravity="center"
            android:text="Logout"
            android:layout_gravity="center"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>